{
  "name": "@hostsmith/mcp-server",
  "version": "0.0.0",
  "description": "MCP server for the Hostsmith hosting platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "hostsmith-mcp-server": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "tsx --env-file=.env src/cli.ts http",
    "start": "tsx src/cli.ts http",
    "build": "tsc && chmod +x dist/cli.js",
    "typecheck": "tsc --noEmit",
    "smoke": "node scripts/smoke.mjs",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@hostsmith/sdk": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "express": "^5.2.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "hostsmith",
    "mcp",
    "model-context-protocol",
    "hosting",
    "deploy"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/hostsmith/mcp-server"
  },
  "homepage": "https://hostsmith.net/docs/developers/mcp",
  "bugs": {
    "url": "https://github.com/hostsmith/mcp-server/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
